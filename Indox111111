                            <select required>
                                <option>كرة قدم</option>
                                <option>كرة سلة</option>
                                <option>متعدد الرياضات</option>
                            </select>
                        </div>
                    `;
                    break;
                case 'member':
                    document.getElementById('modalTitle').textContent = 'إضافة عضو جديد';
                    formHTML = `
                        <div class="form-group">
                            <label>الاسم الكامل</label>
                            <input type="text" required>
                        </div>
