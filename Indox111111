                        </div>
                        <div class="form-group">
                            <label>رقم الهاتف</label>
                            <input type="tel" required>
                        </div>
                    `;
                    break;
                case 'program':
                    document.getElementById('modalTitle').textContent = 'إضافة برنامج جديد';
                    formHTML = `
                        <div class="form-group">
                            <label>اسم البرنامج</label>
                            <input type="text" required>
                        </div>
                        <div class="form-group">
                            <label>الفئة</label>
                            <input type="text" required>
                        </div>
                        <div class="form-group">
                            <label>عدد الجلسات</label>
                            <input type="number" required>
                        </div>
                    `;
                    break;
            }

            document.getElementById('modalBody').innerHTML = formHTML;
        }

        function closeModal() {
            document.getElementById('modal').style.display = 'none';
        }

        function saveItem(event) {
            event.preventDefault();
            alert('تم حفظ البيانات بنجاح');
            closeModal();
        }

        // دوال التعديل والحذف
        function editItem(id) { alert('تعديل البيان رقم: ' + id); }
        function deleteItem(id) { if(confirm('هل تريد حذف هذا البيان؟')) alert('تم الحذف'); }

        function saveSettings(event) {
            event.preventDefault();
            alert('تم حفظ الإعدادات بنجاح');
        }

        // إغلاق الـ Modal عند الضغط خارجه
        window.onclick = function(event) {
            const modal = document.getElementById('modal');
            if (event.target === modal) {
                modal.style.display = 'none';
            }
        }

        // تحميل الصفحة الرئيسية عند البدء
        document.addEventListener('DOMContentLoaded', function() {
            loadPage('dashboard');
        });
