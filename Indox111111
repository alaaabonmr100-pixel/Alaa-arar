<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TOCS-APA 2026 | بروتوكول التدبير الوقائي</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* ============ تعريف الألوان والمتغيرات ============ */
        :root {
            --primary: #003366;
            --accent: #27ae60;
            --light: #f3f0df;
            --dark: #1a1a1a;
            --gray: #ecf0f1;
            --gold: #d4af37;
            --shadow: 0 15px 35px rgba(0, 51, 102, 0.15);
            --transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        /* ============ Reset وأساسيات ============ */
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
            font-family: 'Segoe UI', 'Cairo', Tahoma, sans-serif; 
        }
        
        html { scroll-behavior: smooth; }
        
        body { 
            background: linear-gradient(135deg, var(--light) 0%, #fffef7 50%, #f0ebe0 100%);
            color: var(--primary);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            text-align: center;
            padding: 40px 20px;
            position: relative;
            overflow-x: hidden;
        }

        /* ============ خلفية متحركة زخرفية ============ */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(circle at 20% 50%, rgba(39, 174, 96, 0.03) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(0, 51, 102, 0.03) 0%, transparent 50%);
            pointer-events: none;
            z-index: -1;
        }

        /* ============ شريط الرأس العلوي ============ */
        .header-bar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 8px;
            background: linear-gradient(90deg, var(--primary), var(--accent), var(--gold), var(--primary));
            background-size: 200% 100%;
            animation: headerFlow 6s ease-in-out infinite;
            z-index: 1000;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }

        @keyframes headerFlow {
            0%, 100% { background-position: 0% center; }
            50% { background-position: 100% center; }
        }

        /* ============ حاوية الغلاف الرئيسي ============ */
        .cover-container {
            max-width: 900px;
            padding: 60px;
            background: white;
            border-radius: 20px;
            box-shadow: var(--shadow), 0 20px 60px rgba(212, 175, 55, 0.08);
            border-right: 10px solid var(--accent);
            position: relative;
            margin-top: 30px;
            animation: slideInUp 0.8s ease-out;
            overflow: hidden;
        }

        /* ============ الخلفية الزخرفية الداخلية ============ */
        .cover-container::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: 
                radial-gradient(circle, rgba(39, 174, 96, 0.02) 1px, transparent 1px);
            background-size: 50px 50px;
            animation: bgShift 20s linear infinite;
            pointer-events: none;
        }

        @keyframes bgShift {
            0% { transform: translate(0, 0); }
            100% { transform: translate(50px, 50px); }
        }

        .cover-container::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            animation: shimmer 3s ease-in-out infinite;
        }

        @keyframes shimmer {
            0%, 100% { opacity: 0; }
            50% { opacity: 1; }
        }

        .cover-container > * { position: relative; z-index: 1; }

        /* ============ علامة المشروع (PROJECT TAG) ============ */
        .project-tag {
            letter-spacing: 5px;
            color: var(--accent);
            margin-bottom: 10px;
            font-weight: bold;
            font-size: 1rem;
            position: relative;
            display: inline-block;
            padding: 8px 20px;
            border: 2px solid var(--accent);
            border-radius: 50px;
            animation: fadeInDown 0.8s ease-out;
        }

        .project-tag::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 6px;
            height: 6px;
            background: var(--accent);
            border-radius: 50%;
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes pulse {
            0%, 100% { transform: translateY(-50%) scale(1); }
            50% { transform: translateY(-50%) scale(1.5); opacity: 0.5; }
        }

        /* ============ العنوان الرئيسي ============ */
        h1 { 
            font-size: 3.5rem; 
            color: var(--primary); 
            margin-bottom: 20px; 
            font-weight: 900;
            letter-spacing: -1px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: fadeInUp 0.8s ease-out 0.1s both;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.05);
        }

        /* ============ الشعار الفرعي ============ */
        .tagline { 
            font-size: 1.5rem; 
            color: #666; 
            margin-bottom: 40px;
            font-weight: 600;
            animation: fadeInUp 0.8s ease-out 0.2s both;
            letter-spacing: 0.5px;
        }

        /* ============ النص الوصفي ============ */
        .description {
            font-size: 1.1rem; 
            margin-top: 20px;
            margin-bottom: 40px;
            color: #555;
            line-height: 1.8;
            animation: fadeInUp 0.8s ease-out 0.3s both;
            padding: 20px;
            border-right: 4px solid var(--accent);
            border-radius: 0 8px 8px 0;
            background: linear-gradient(90deg, transparent, rgba(39, 174, 96, 0.05));
        }

        /* ============ منطقة المصفوفة ============ */
        .matrix-section { 
            margin-top: 50px; 
            text-align: right;
            animation: fadeInUp 0.8s ease-out 0.4s both;
        }

        .matrix-section h3 {
            color: var(--primary);
            margin-bottom: 20px;
            font-size: 1.8rem;
            position: relative;
            display: inline-block;
            padding-bottom: 10px;
        }

        .matrix-section h3::after {
            content: '';
            position: absolute;
            bottom: 0;
            right: 0;
            left: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--accent), var(--gold), var(--accent));
            border-radius: 2px;
            animation: expandWidth 0.8s ease-out;
        }

        @keyframes expandWidth {
            from { width: 0; right: 50%; }
            to { width: 100%; right: 0; }
        }

        /* ============ تنسيق الجداول ============ */
        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-top: 30px;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
        }
        
        thead {
            background: linear-gradient(135deg, var(--primary) 0%, #004d99 100%);
            position: relative;
        }

        th {
            color: white;
            padding: 18px 15px;
            text-align: center;
            font-weight: 700;
            font-size: 1rem;
            letter-spacing: 0.5px;
            position: relative;
            transition: var(--transition);
        }

        th::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        tbody tr:first-child th::after {
            opacity: 1;
        }
        
        td {
            border-bottom: 1px solid #e0e0e0;
            padding: 18px 15px;
            text-align: center;
            font-weight: 500;
            transition: var(--transition);
            position: relative;
        }

        tbody tr:last-child td {
            border-bottom: none;
        }
        
        tbody tr {
            background: white;
            transition: var(--transition);
        }

        tbody tr:nth-child(odd) { 
            background: linear-gradient(90deg, transparent, rgba(39, 174, 96, 0.02), transparent);
        }
        
        tbody tr:hover {
            background: linear-gradient(90deg, rgba(39, 174, 96, 0.08), rgba(39, 174, 96, 0.12), rgba(39, 174, 96, 0.08));
            box-shadow: inset 0 4px 8px rgba(0, 0, 0, 0.05);
            transform: scale(1.01);
        }

        tbody tr:hover td {
            color: var(--primary);
            font-weight: 600;
        }

        /* ============ تنسيق الرموز ============ */
        td:first-child {
            background: linear-gradient(135deg, var(--primary), #004d99);
            color: white;
            font-weight: 900;
            font-size: 1.3rem;
            border-radius: 8px 0 0 8px;
            position: relative;
        }

        td:first-child::before {
            content: '';
            position: absolute;
            left: -2px;
            top: 50%;
            transform: translateY(-50%);
            width: 4px;
            height: 20px;
            background: var(--gold);
            border-radius: 2px;
        }

        /* ============ قسم الشركاء ============ */
        .partners-section { 
            margin-top: 60px; 
            border-top: 3px dashed var(--gray);
            padding-top: 40px;
            animation: fadeInUp 0.8s ease-out 0.5s both;
        }
        
        .partners-section h3 { 
            color: var(--primary); 
            margin-bottom: 20px;
            font-size: 1.6rem;
            position: relative;
        }

        .partners-section h3::before {
            content: '';
            display: block;
            width: 50px;
            height: 3px;
            background: linear-gradient(90deg, var(--accent), var(--gold));
            margin: 0 auto 10px;
            border-radius: 2px;
        }
        
        .partner-list { 
            font-size: 1.2rem; 
            color: var(--primary);
            font-weight: 700;
            letter-spacing: 1px;
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 15px;
        }

        .partner-item {
            padding: 12px 20px;
            background: linear-gradient(135deg, rgba(0, 51, 102, 0.05), rgba(39, 174, 96, 0.05));
            border: 2px solid var(--accent);
            border-radius: 25px;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .partner-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.3), transparent);
            transition: left 0.5s ease;
        }

        .partner-item:hover {
            background: linear-gradient(135deg, var(--accent), rgba(39, 174, 96, 0.15));
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(39, 174, 96, 0.25);
            border-color: var(--accent);
        }

        .partner-item:hover::before {
            left: 100%;
        }

        /* ============ الديكور الهندسي ============ */
        .geometric-decoration {
            position: absolute;
            opacity: 0.1;
            pointer-events: none;
        }

        .decoration-1 {
            top: 20px;
            right: 20px;
            width: 100px;
            height: 100px;
            border: 3px solid var(--accent);
            border-radius: 50%;
            animation: rotateZ 20s linear infinite;
        }

        .decoration-2 {
            bottom: 20px;
            left: 20px;
            width: 80px;
            height: 80px;
            border: 3px solid var(--primary);
            animation: rotateZ 25s linear infinite reverse;
        }

        @keyframes rotateZ {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* ============ الحركات العامة ============ */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ============ Responsive Design ============ */
        @media (max-width: 768px) {
            .cover-container {
                padding: 30px;
                margin: 15px;
            }

            h1 {
                font-size: 2.2rem;
            }

            .tagline {
                font-size: 1.1rem;
            }

            table {
                font-size: 0.9rem;
            }

            th, td {
                padding: 12px 8px;
            }

            .matrix-section h3 {
                font-size: 1.3rem;
            }

            .partner-list {
                flex-direction: column;
                gap: 10px;
            }

            .partner-item {
                width: 100%;
            }

            .description {
                font-size: 1rem;
                padding: 15px;
            }
        }

        /* ============ تأثيرات إضافية ============ */
        .glow-effect {
            position: relative;
        }

        .glow-effect::before {
            content: '';
            position: absolute;
            top: -5px;
            left: -5px;
            right: -5px;
            bottom: -5px;
            background: linear-gradient(135deg, var(--accent), var(--gold));
            border-radius: 20px;
            opacity: 0;
            z-index: -1;
            transition: opacity 0.3s ease;
            animation: glowPulse 3s ease-in-out infinite;
        }

        @keyframes glowPulse {
            0%, 100% { opacity: 0; }
            50% { opacity: 0.1; }
        }

        /* ============ الأيقونات والرموز ============ */
        .status-icon {
            display: inline-block;
            width: 12px;
            height: 12px;
            background: var(--accent);
            border-radius: 50%;
            animation: statusPulse 2s ease-in-out infinite;
            margin: 0 5px;
        }

        @keyframes statusPulse {
            0%, 100% { 
                box-shadow: 0 0 0 0 rgba(39, 174, 96, 0.7);
            }
            50% {
                box-shadow: 0 0 0 6px rgba(39, 174, 96, 0);
            }
        }

        /* ============ التوهج على الهوفر ============ */
        .hover-glow:hover {
            filter: drop-shadow(0 0 10px rgba(39, 174, 96, 0.5));
        }

    </style>
</head>
<body>

    <div class="header-bar"></div>

    <div class="cover-container glow-effect">
        <div class="geometric-decoration decoration-1"></div>
        <div class="geometric-decoration decoration-2"></div>

        <p class="project-tag">
            <i class="fas fa-star"></i> PROJECT 2026
        </p>
        
        <h1>TOCS-APA 2026</h1>
        
        <p class="tagline">
            <i class="fas fa-heartbeat"></i> بروتوكول التدبير الوقائي | مصفوفة العمليات التشغيلية (SOP Matrix)
        </p>
        
        <p class="description">
            <i class="fas fa-flask-vial"></i> نظام هندسي طبي رياضي احترافي لفرز وإدارة الحركة، مصمم بواسطة: <strong>كابتن علاء عرار</strong>.
        </p>

        <div class="matrix-section">
            <h3><i class="fas fa-table"></i> مصفوفة العمليات التشغيلية [M,I,O,S,P]</h3>
            <table>
                <thead>
                    <tr>
                        <th><i class="fas fa-tag"></i> الرمز</th>
                        <th><i class="fas fa-stethoscope"></i> الحالة / النطاق</th>
                        <th><i class="fas fa-exclamation-triangle"></i> مستوى الخطورة</th>
                        <th><i class="fas fa-shield-alt"></i> التدبير الوقائي</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="status-icon"></span> [M]</td>
                        <td>اضطرابات حركية</td>
                        <td><strong>High Mechanical</strong></td>
                        <td>تعديل المدى الحركي (ROM Adjustment)</td>
                    </tr>
                    <tr>
                        <td><span class="status-icon"></span> [I]</td>
                        <td>حالات طبية (سكر/ضغط)</td>
                        <td><strong>High Physiological</strong></td>
                        <td>مراقبة RPE وتجنب مناورة فالسلفا</td>
                    </tr>
                    <tr>
                        <td><span class="status-icon"></span> [O]</td>
                        <td>السمنة / تركيب الجسم</td>
                        <td><strong>Moderate Mechanical</strong></td>
                        <td>تقليل قوى الصدمات (Impact Control)</td>
                    </tr>
                    <tr>
                        <td><span class="status-icon"></span> [S]</td>
                        <td>دعم نفسي واجتماعي</td>
                        <td><strong>Low Physiological</strong></td>
                        <td>تعزيز التفاعل والتحفيز التدريجي</td>
                    </tr>
                    <tr>
                        <td><span class="status-icon"></span> [P]</td>
                        <td>إعداد بدني متقدم</td>
                        <td><strong>Controlled Load</strong></td>
                        <td>تطبيق مبدأ الدورية (Periodization)</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="partners-section">
            <h3><i class="fas fa-certificate"></i> المنظمات المعتمدة (Accredited Frameworks)</h3>
            <div class="partner-list">
                <span class="partner-item"><i class="fas fa-globe"></i> WHO</span>
                <span class="partner-item"><i class="fas fa-dumbbell"></i> ACSM</span>
                <span class="partner-item"><i class="fas fa-user-tie"></i> NSCA</span>
                <span class="partner-item"><i class="fas fa-heartbeat"></i> FIMS/IOC</span>
            </div>
        </div>
    </div>

</body>
</html>